<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DataTemplate x:Key="AstroCircular SkyWaver_Options">
        <StackPanel Orientation="Vertical" MaxWidth="640" Margin="5">

            <!-- SkyWave Output Folder with browse button -->
            <GroupBox Header="SkyWave Output Folder" Margin="0,0,0,6" BorderBrush="#3a5" BorderThickness="1.5">
                <StackPanel Margin="6,3">
                    <TextBlock Text="Folder that SkyWave watches for new FITS files." Foreground="#999" FontSize="10" Margin="0,0,0,2" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding Settings.SkyWaveOutputDirectory, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1" Content=" Browse... " Margin="4,0,0,0" Padding="8,2"
                                Command="{Binding BrowseFolderCommand}" />
                    </Grid>
                </StackPanel>
            </GroupBox>

            <!-- Post-Capture Integration -->
            <GroupBox Header="Post-Capture Integration" Margin="0,0,0,4">
                <StackPanel Margin="6,2">
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <CheckBox IsChecked="{Binding Settings.CropToCircle}" VerticalAlignment="Center" />
                        <TextBlock Text="Crop to inscribed circle — removes corners outside ring pattern" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <CheckBox IsChecked="{Binding Settings.BinToHalf}" VerticalAlignment="Center" />
                        <TextBlock Text="Bin 2x after integration — halves resolution for SkyWave" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <CheckBox IsChecked="{Binding Settings.AutoCleanSubFrames}" VerticalAlignment="Center" />
                        <TextBlock Text="Auto-delete sub-frames — keeps only the integrated FITS" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2">
                        <CheckBox IsChecked="{Binding Settings.IncludeCenter}" VerticalAlignment="Center" />
                        <TextBlock Text="Include center position — extra frame at star center" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- Equipment (from NINA profile) -->
            <GroupBox Header="Equipment (from NINA profile — override if needed)" Margin="0,0,0,4">
                <Grid Margin="6,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Focal L. mm" VerticalAlignment="Center" />
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Settings.FocalLengthMm, StringFormat={}{0:F1}, UpdateSourceTrigger=LostFocus}" Margin="2,1" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Aperture mm" VerticalAlignment="Center" Margin="6,0,0,0" />
                    <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding Settings.ApertureMm, StringFormat={}{0:F1}, UpdateSourceTrigger=LostFocus}" Margin="2,1" />
                    <TextBlock Grid.Row="0" Grid.Column="4" Text="Pixel Size um" VerticalAlignment="Center" Margin="6,0,0,0" />
                    <TextBox Grid.Row="0" Grid.Column="5" Text="{Binding Settings.PixelSizeUm, StringFormat={}{0:F2}, UpdateSourceTrigger=LostFocus}" Margin="2,1" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Sensor W mm" VerticalAlignment="Center" />
                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Settings.SensorWidthMm, StringFormat={}{0:F1}, UpdateSourceTrigger=LostFocus}" Margin="2,1" />
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="Sensor H mm" VerticalAlignment="Center" Margin="6,0,0,0" />
                    <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding Settings.SensorHeightMm, StringFormat={}{0:F1}, UpdateSourceTrigger=LostFocus}" Margin="2,1" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Latitude" VerticalAlignment="Center" />
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Settings.ObserverLatitude, StringFormat={}{0:F2}, UpdateSourceTrigger=LostFocus}" Margin="2,1" />
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="Longitude" VerticalAlignment="Center" Margin="6,0,0,0" />
                    <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding Settings.ObserverLongitude, StringFormat={}{0:F2}, UpdateSourceTrigger=LostFocus}" Margin="2,1" />
                </Grid>
            </GroupBox>

            <TextBlock Margin="0,2,0,0" FontSize="10" Foreground="#888" TextWrapping="Wrap"
                       Text="v0.2.0 by joergsflow | github.com/joergs-git/astrocircular-skywaver-for-nina | innovationsforesight.com/aitelescopecollimation" />
        </StackPanel>
    </DataTemplate>

</ResourceDictionary>
