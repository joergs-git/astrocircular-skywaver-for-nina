<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:NINA.AstroCircular.SkyWaver.SequenceContainers">

    <!-- Inline sequencer display for SkwCollimationRun -->
    <DataTemplate DataType="{x:Type local:SkwCollimationRun}">
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="SKW Collimation Run: " FontWeight="Bold" />
            <TextBlock Text="{Binding StarName}" />
            <TextBlock Text=" | " />
            <TextBlock Text="{Binding RingPositions}" />
            <TextBlock Text=" pos | " />
            <TextBlock Text="{Binding DefocusSteps}" />
            <TextBlock Text=" steps" />
        </StackPanel>
    </DataTemplate>

</ResourceDictionary>
