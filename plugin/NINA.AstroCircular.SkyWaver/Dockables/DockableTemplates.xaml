<ResourceDictionary
    x:Class="NINA.AstroCircular.SkyWaver.Dockables.DockableTemplates"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DataTemplate x:Key="NINA.AstroCircular.SkyWaver.Dockables.SkwPanelVM_Dockable">
        <StackPanel Margin="5">

            <!-- Star Selection -->
            <Grid Margin="0,0,0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Star:" VerticalAlignment="Center" Margin="0,0,4,0" FontWeight="Bold" />
                <ComboBox Grid.Column="1" ItemsSource="{Binding StarPresets}" SelectedItem="{Binding SelectedPreset}"
                          DisplayMemberPath="Name" Margin="0,0,4,0" />
                <Button Grid.Column="2" Content="Find Best" Command="{Binding FindBestStarCommand}" Padding="8,2" />
            </Grid>

            <!-- RA / Dec -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="32" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="RA" VerticalAlignment="Center" FontSize="11" />
                <TextBox Grid.Column="1" Text="{Binding TargetRA, UpdateSourceTrigger=PropertyChanged}" Margin="2,0" FontSize="11" />
                <TextBlock Grid.Column="2" Text="Dec" VerticalAlignment="Center" Margin="6,0,0,0" FontSize="11" />
                <TextBox Grid.Column="3" Text="{Binding TargetDec, UpdateSourceTrigger=PropertyChanged}" Margin="2,0" FontSize="11" />
            </Grid>

            <!-- Parameters (compact 3-column grid) -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="58" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="42" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="46" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Defocus" VerticalAlignment="Center" FontSize="11" />
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding DefocusSteps, UpdateSourceTrigger=PropertyChanged}" Margin="2,1" FontSize="11" />
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Dir" VerticalAlignment="Center" FontSize="11" Margin="4,0,0,0" />
                <ComboBox Grid.Row="0" Grid.Column="3" SelectedValue="{Binding DefocusDirection}" Margin="2,1" FontSize="11">
                    <ComboBoxItem Content="Extra +" Tag="1" />
                    <ComboBoxItem Content="Intra -" Tag="-1" />
                </ComboBox>
                <TextBlock Grid.Row="0" Grid.Column="4" Text="Exp s" VerticalAlignment="Center" FontSize="11" Margin="4,0,0,0" />
                <TextBox Grid.Row="0" Grid.Column="5" Text="{Binding ExposureTime, UpdateSourceTrigger=PropertyChanged}" Margin="2,1" FontSize="11" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Filter" VerticalAlignment="Center" FontSize="11" />
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding FilterName, UpdateSourceTrigger=PropertyChanged}" Margin="2,1" FontSize="11" />
                <TextBlock Grid.Row="1" Grid.Column="2" Text="Gain" VerticalAlignment="Center" FontSize="11" Margin="4,0,0,0" />
                <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding Gain, UpdateSourceTrigger=PropertyChanged}" Margin="2,1" FontSize="11" />
                <TextBlock Grid.Row="1" Grid.Column="4" Text="Offset" VerticalAlignment="Center" FontSize="11" Margin="4,0,0,0" />
                <TextBox Grid.Row="1" Grid.Column="5" Text="{Binding Offset, UpdateSourceTrigger=PropertyChanged}" Margin="2,1" FontSize="11" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Pos." VerticalAlignment="Center" FontSize="11" />
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding RingPositions, UpdateSourceTrigger=PropertyChanged}" Margin="2,1" FontSize="11" />
                <TextBlock Grid.Row="2" Grid.Column="2" Text="Rad%" VerticalAlignment="Center" FontSize="11" Margin="4,0,0,0" />
                <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding RadiusPercent, UpdateSourceTrigger=PropertyChanged}" Margin="2,1" FontSize="11" />
                <TextBlock Grid.Row="2" Grid.Column="4" Text="Settle" VerticalAlignment="Center" FontSize="11" Margin="4,0,0,0" />
                <TextBox Grid.Row="2" Grid.Column="5" Text="{Binding SettleSeconds, UpdateSourceTrigger=PropertyChanged}" Margin="2,1" FontSize="11" />
            </Grid>

            <!-- Run / Cancel -->
            <Grid Margin="0,0,0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Run Collimation" Command="{Binding RunCommand}"
                        Padding="8,6" FontWeight="Bold" FontSize="13"
                        Background="#22a558" Foreground="White" BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Grid.Column="1" Content="Cancel" Command="{Binding CancelCommand}"
                        Padding="8,6" Margin="4,0,0,0" FontSize="13"
                        Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}" />
            </Grid>

            <!-- Progress -->
            <ProgressBar Value="{Binding Progress}" Minimum="0" Maximum="100" Height="4" Margin="0,0,0,2" />
            <TextBlock Text="{Binding StatusText}" FontSize="10" Foreground="#999" TextWrapping="Wrap" />

            <!-- Sensor Map + Camera Preview side by side -->
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Sensor Map -->
                <Border Grid.Column="0" BorderBrush="#272d42" BorderThickness="1" CornerRadius="3"
                        Background="#080a10" Margin="0,0,2,0" MinHeight="200">
                    <Grid>
                        <Canvas HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                ClipToBounds="True">
                            <!-- Position dots via ItemsControl -->
                            <ItemsControl ItemsSource="{Binding MapPositions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding CanvasX}" />
                                        <Setter Property="Canvas.Top" Value="{Binding CanvasY}" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="-7,-7,0,0">
                                            <Ellipse Width="14" Height="14" StrokeThickness="1.5">
                                                <Ellipse.Stroke>
                                                    <SolidColorBrush Color="{Binding StrokeColor}" />
                                                </Ellipse.Stroke>
                                                <Ellipse.Fill>
                                                    <SolidColorBrush Color="{Binding FillColor}" Opacity="0.15" />
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <Ellipse Width="5" Height="5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Ellipse.Fill>
                                                    <SolidColorBrush Color="{Binding FillColor}" />
                                                </Ellipse.Fill>
                                            </Ellipse>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Canvas>

                        <!-- Labels overlay -->
                        <TextBlock Text="Pattern" FontSize="9" Foreground="#444"
                                   HorizontalAlignment="Left" VerticalAlignment="Top" Margin="4,2" />
                        <TextBlock Text="{Binding ProgressText}" FontSize="10" Foreground="#666"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,4,2" />
                    </Grid>
                </Border>

                <!-- Camera Preview -->
                <Border Grid.Column="1" BorderBrush="#272d42" BorderThickness="1" CornerRadius="3"
                        Background="#080a10" Margin="2,0,0,0" MinHeight="200">
                    <Grid>
                        <Image Source="{Binding LastCapturedImage}" Stretch="Uniform"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <TextBlock Text="Preview" FontSize="9" Foreground="#444"
                                   HorizontalAlignment="Left" VerticalAlignment="Top" Margin="4,2" />
                        <!-- Placeholder when no image -->
                        <TextBlock Text="No image yet" FontSize="11" Foreground="#333"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Visibility="{Binding LastCapturedImage, Converter={StaticResource NullToVisibilityConverter}}" />
                    </Grid>
                </Border>
            </Grid>

        </StackPanel>
    </DataTemplate>

</ResourceDictionary>
