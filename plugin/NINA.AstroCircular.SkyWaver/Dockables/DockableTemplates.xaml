<ResourceDictionary
    x:Class="NINA.AstroCircular.SkyWaver.Dockables.DockableTemplates"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DataTemplate x:Key="NINA.AstroCircular.SkyWaver.Dockables.SkwPanelVM_Dockable">
        <StackPanel Margin="5">

            <!-- Star Selection -->
            <Grid Margin="0,0,0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Star:" VerticalAlignment="Center" Margin="0,0,4,0" FontWeight="Bold" />
                <ComboBox Grid.Column="1" ItemsSource="{Binding StarPresets}" SelectedItem="{Binding SelectedPreset}"
                          DisplayMemberPath="Name" Margin="0,0,4,0" />
                <Button Grid.Column="2" Content="Find Best" Command="{Binding FindBestStarCommand}" Padding="8,2" />
            </Grid>

            <!-- RA / Dec -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="32" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="RA" VerticalAlignment="Center" FontSize="11" />
                <TextBox Grid.Column="1" Text="{Binding TargetRA, UpdateSourceTrigger=PropertyChanged}" Margin="2,0" FontSize="11" />
                <TextBlock Grid.Column="2" Text="Dec" VerticalAlignment="Center" Margin="6,0,0,0" FontSize="11" />
                <TextBox Grid.Column="3" Text="{Binding TargetDec, UpdateSourceTrigger=PropertyChanged}" Margin="2,0" FontSize="11" />
            </Grid>

            <!-- Parameters (compact 3-column grid) -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="58" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="42" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="46" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Defocus" VerticalAlignment="Center" FontSize="11" />
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding DefocusSteps, UpdateSourceTrigger=PropertyChanged}" Margin="2,1" FontSize="11" />
                <TextBlock Grid.Row="0" Grid.Column="2" Text="Dir" VerticalAlignment="Center" FontSize="11" Margin="4,0,0,0" />
                <ComboBox Grid.Row="0" Grid.Column="3" SelectedIndex="{Binding DefocusDirectionIndex}" Margin="2,1" FontSize="11">
                    <ComboBoxItem Content="Extra-focal (+)" />
                    <ComboBoxItem Content="Intra-focal (-)" />
                </ComboBox>
                <TextBlock Grid.Row="0" Grid.Column="4" Text="Exp s" VerticalAlignment="Center" FontSize="11" Margin="4,0,0,0" />
                <TextBox Grid.Row="0" Grid.Column="5" Text="{Binding ExposureTime, UpdateSourceTrigger=PropertyChanged}" Margin="2,1" FontSize="11" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Filter" VerticalAlignment="Center" FontSize="11" />
                <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding AvailableFilters}"
                          SelectedItem="{Binding FilterName}" Margin="2,1" FontSize="11" />
                <TextBlock Grid.Row="1" Grid.Column="2" Text="Gain" VerticalAlignment="Center" FontSize="11" Margin="4,0,0,0" />
                <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding Gain, UpdateSourceTrigger=PropertyChanged}" Margin="2,1" FontSize="11" />
                <TextBlock Grid.Row="1" Grid.Column="4" Text="Offset" VerticalAlignment="Center" FontSize="11" Margin="4,0,0,0" />
                <TextBox Grid.Row="1" Grid.Column="5" Text="{Binding Offset, UpdateSourceTrigger=PropertyChanged}" Margin="2,1" FontSize="11" />

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Pos." VerticalAlignment="Center" FontSize="11" />
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding RingPositions, UpdateSourceTrigger=PropertyChanged}" Margin="2,1" FontSize="11" />
                <TextBlock Grid.Row="2" Grid.Column="2" Text="Rad%" VerticalAlignment="Center" FontSize="11" Margin="4,0,0,0" />
                <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding RadiusPercent, UpdateSourceTrigger=PropertyChanged}" Margin="2,1" FontSize="11" />
                <TextBlock Grid.Row="2" Grid.Column="4" Text="Settle" VerticalAlignment="Center" FontSize="11" Margin="4,0,0,0" />
                <TextBox Grid.Row="2" Grid.Column="5" Text="{Binding SettleSeconds, UpdateSourceTrigger=PropertyChanged}" Margin="2,1" FontSize="11" />
            </Grid>

            <!-- Toggles -->
            <WrapPanel Margin="0,0,0,4">
                <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                    <CheckBox IsChecked="{Binding CropToCircle}" VerticalAlignment="Center" />
                    <TextBlock Text="Crop" Margin="4,0,0,0" FontSize="10" VerticalAlignment="Center"
                               ToolTip="Crop to square inscribed in the ring pattern" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                    <CheckBox IsChecked="{Binding BinToHalf}" VerticalAlignment="Center" />
                    <TextBlock Text="Bin2x" Margin="4,0,0,0" FontSize="10" VerticalAlignment="Center"
                               ToolTip="2x2 downsample after integration" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                    <CheckBox IsChecked="{Binding IncludeCenter}" VerticalAlignment="Center" />
                    <TextBlock Text="Center" Margin="4,0,0,0" FontSize="10" VerticalAlignment="Center"
                               ToolTip="Include center star position" />
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <CheckBox IsChecked="{Binding AutoCleanSubFrames}" VerticalAlignment="Center" />
                    <TextBlock Text="Auto-delete subs" Margin="4,0,0,0" FontSize="10" VerticalAlignment="Center"
                               ToolTip="Delete individual frames after integration" />
                </StackPanel>
            </WrapPanel>

            <!-- SkyWave Output Folder -->
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Output:" VerticalAlignment="Center" FontSize="11" Margin="0,0,4,0" />
                <TextBox Grid.Column="1" Text="{Binding SkyWaveOutputDirectory, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="10" ToolTip="SkyWave watch folder — integrated FITS saved here" />
                <Button Grid.Column="2" Content=" ... " Command="{Binding BrowseFolderCommand}"
                        Padding="6,1" Margin="2,0,0,0" ToolTip="Browse for output folder" />
            </Grid>

            <!-- Run / Cancel -->
            <Grid Margin="0,0,0,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="Run Collimation" Command="{Binding RunCommand}"
                        Padding="8,6" FontWeight="Bold" FontSize="13"
                        Background="#22a558" Foreground="White" BorderThickness="0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Grid.Column="1" Content="Cancel" Command="{Binding CancelCommand}"
                        Padding="8,6" Margin="4,0,0,0" FontSize="13"
                        Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityCollapsedConverter}}" />
            </Grid>

            <!-- Progress -->
            <ProgressBar Value="{Binding Progress}" Minimum="0" Maximum="100" Height="4" Margin="0,0,0,2" />
            <TextBlock Text="{Binding StatusText}" FontSize="10" Foreground="#999" TextWrapping="Wrap" />

            <!-- Sensor Map + Camera Preview side by side -->
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Sensor Map — frame = sensor rectangle, aspect ratio matches real sensor -->
                <Border Grid.Column="0" BorderBrush="#3a4060" BorderThickness="1.5"
                        Background="#080a10" Margin="0,0,2,0"
                        Width="{Binding MapWidth}" Height="{Binding MapHeight}"
                        HorizontalAlignment="Center">
                    <Grid>
                        <Canvas Width="{Binding MapWidth}" Height="{Binding MapHeight}"
                                ClipToBounds="True">
                            <!-- Position dots via ItemsControl -->
                            <ItemsControl ItemsSource="{Binding MapPositions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding CanvasX}" />
                                        <Setter Property="Canvas.Top" Value="{Binding CanvasY}" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="-7,-7,0,0">
                                            <Ellipse Width="14" Height="14" StrokeThickness="1.5">
                                                <Ellipse.Stroke>
                                                    <SolidColorBrush Color="{Binding StrokeColor}" />
                                                </Ellipse.Stroke>
                                                <Ellipse.Fill>
                                                    <SolidColorBrush Color="{Binding FillColor}" Opacity="0.15" />
                                                </Ellipse.Fill>
                                            </Ellipse>
                                            <Ellipse Width="5" Height="5" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Ellipse.Fill>
                                                    <SolidColorBrush Color="{Binding FillColor}" />
                                                </Ellipse.Fill>
                                            </Ellipse>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Canvas>

                        <!-- Labels overlay -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="4,2">
                            <Path Data="{StaticResource SkwMiniIconSVG}" Fill="#444" Width="9" Height="9" Stretch="Uniform" Margin="0,0,3,0" />
                            <TextBlock Text="Pattern" FontSize="9" Foreground="#444" />
                        </StackPanel>
                        <TextBlock Text="{Binding ProgressText}" FontSize="10" Foreground="#666"
                                   HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,4,2" />
                    </Grid>
                </Border>

                <!-- Camera Preview — same aspect ratio as sensor map -->
                <Border Grid.Column="1" BorderBrush="#272d42" BorderThickness="1"
                        Background="#080a10" Margin="2,0,0,0"
                        Width="{Binding MapWidth}" Height="{Binding MapHeight}"
                        HorizontalAlignment="Center">
                    <Grid>
                        <Image Source="{Binding LastCapturedImage}" Stretch="Uniform"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="4,2">
                            <Path Data="{StaticResource SkwMiniIconSVG}" Fill="#444" Width="9" Height="9" Stretch="Uniform" Margin="0,0,3,0" />
                            <TextBlock Text="Last Capture" FontSize="9" Foreground="#444" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

        </StackPanel>
    </DataTemplate>

    <!-- Plugin icon: 3 concentric circles + center dot (collimation target) -->
    <GeometryGroup x:Key="SkwPanelIconSVG" FillRule="Nonzero">
        <!-- Large circle -->
        <EllipseGeometry Center="16,16" RadiusX="14.5" RadiusY="14.5" />
        <EllipseGeometry Center="16,16" RadiusX="13.2" RadiusY="13.2" />
        <!-- Medium circle -->
        <EllipseGeometry Center="16,16" RadiusX="9.5" RadiusY="9.5" />
        <EllipseGeometry Center="16,16" RadiusX="8.2" RadiusY="8.2" />
        <!-- Small circle -->
        <EllipseGeometry Center="16,16" RadiusX="5" RadiusY="5" />
        <EllipseGeometry Center="16,16" RadiusX="3.7" RadiusY="3.7" />
        <!-- Center dot -->
        <EllipseGeometry Center="16,16" RadiusX="1.2" RadiusY="1.2" />
    </GeometryGroup>

    <!-- Small inline icon (10x10) for labels -->
    <GeometryGroup x:Key="SkwMiniIconSVG" FillRule="Nonzero">
        <EllipseGeometry Center="5,5" RadiusX="4.5" RadiusY="4.5" />
        <EllipseGeometry Center="5,5" RadiusX="4.0" RadiusY="4.0" />
        <EllipseGeometry Center="5,5" RadiusX="3.0" RadiusY="3.0" />
        <EllipseGeometry Center="5,5" RadiusX="2.5" RadiusY="2.5" />
        <EllipseGeometry Center="5,5" RadiusX="1.5" RadiusY="1.5" />
        <EllipseGeometry Center="5,5" RadiusX="1.0" RadiusY="1.0" />
        <EllipseGeometry Center="5,5" RadiusX="0.4" RadiusY="0.4" />
    </GeometryGroup>

</ResourceDictionary>
